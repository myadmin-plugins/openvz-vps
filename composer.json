{
	"name": "detain/myadmin-openvz-vps",
	"type": "myadmin-plugin",
	"description": "MyAdmin OpenVZ VPS plugin — provides container-based VPS provisioning, settings management, and queue handling via Symfony EventDispatcher hooks.",
	"keywords": [
		"openvz",
		"vps",
		"virtualization",
		"container",
		"myadmin",
		"administration",
		"plugin"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https://my.interserver.net/"
		}
	],
	"config": {
		"bin-dir": "vendor/bin",
		"minimum-stability": "dev",
		"allow-plugins": {
			"detain/myadmin-plugin-installer": true
		}
	},
	"require": {
		"php": ">=8.2",
		"ext-soap": "*",
		"symfony/event-dispatcher": "^5.0|^6.0|^7.0",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminOpenvz\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminOpenvz\\Tests\\": "tests/"
		}
	}
}
